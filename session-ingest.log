+    - id: rule-multidisciplinary-management
+      event: assess-neoadjuvant-candidacy
+      phase: candidacy
+      then:
+        - coordinate-multidisciplinary-management
+      evidence_traceability_ids: [claim-general-team]
+      provenance:
+        source: source_direct
+    - id: rule-r1-1-advanced-disease
+      event: assess-neoadjuvant-candidacy
+      phase: candidacy
+      when:
+        inflammatory-or-locally-advanced: Yes
+      then:
+        - offer-neoadjuvant-chemotherapy-for-advanced-disease
+      evidence_traceability_ids: [claim-r1-1]
+      provenance:
+        source: source_direct
+    - id: rule-r1-2-standard-features
+      event: assess-neoadjuvant-candidacy
+      phase: candidacy
+      when:
+        standard-tumor-features-available: Yes
+      then:
+        - use-standard-tumor-features
+        - avoid-other-markers
+      evidence_traceability_ids: [claim-r1-2]
+      provenance:
+        source: source_direct
+    - id: rule-r1-3-residual-disease-guided
+      event: assess-neoadjuvant-candidacy
+      phase: candidacy
+      when:
+        residual-disease-would-change-adjuvant-therapy: Yes
+      then:
+        - offer-neoadjuvant-for-residual-disease-guided-adjuvant-planning
+      evidence_traceability_ids: [claim-r1-3]
+      provenance:
+        source: source_direct
+    - id: rule-r1-4-downstaging
+      event: assess-neoadjuvant-candidacy
+      phase: candidacy
+      when:
+        local-therapy-downstaging-goal: Yes
+      then:
+        - offer-neoadjuvant-for-downstaging
+      evidence_traceability_ids: [claim-r1-4]
+      provenance:
+        source: source_direct
+    - id: rule-r1-5-surgery-delay
+      event: assess-neoadjuvant-candidacy
+      phase: candidacy
+      when:
+        surgery-delay-context: Yes
+      then:
+        - offer-neoadjuvant-for-surgery-delay
+      evidence_traceability_ids: [claim-r1-5]
+      provenance:
+        source: source_direct
+    - id: rule-r2-1-monitoring
+      event: monitor-neoadjuvant-response
+      phase: monitoring
+      then:
+        - monitor-with-clinical-examination
+        - use-baseline-informative-imaging
+      evidence_traceability_ids: [claim-r2-1]
+      provenance:
+        source: source_direct
+    - id: rule-r2-2-no-biomarkers
