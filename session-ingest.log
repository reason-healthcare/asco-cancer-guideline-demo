+      phase: monitoring
+      then:
+        - avoid-blood-and-tissue-biomarker-monitoring
+      evidence_traceability_ids: [claim-r2-2]
+      provenance:
+        source: source_direct
+    - id: rule-r2-3-use-pcr
+      event: monitor-neoadjuvant-response
+      phase: monitoring
+      then:
+        - use-pcr-to-guide-decisions
+      evidence_traceability_ids: [claim-r2-3]
+      provenance:
+        source: source_direct
+    - id: rule-r3-1-tnbc-eligible
+      event: select-tnbc-regimen
+      phase: tnbc
+      when:
+        tnbc-node-positive-or-t1c-plus: Yes
+      then:
+        - offer-anthracycline-taxane-for-tnbc
+      evidence_traceability_ids: [claim-r3-1]
+      provenance:
+        source: source_direct
+    - id: rule-r3-2-tnbc-small-node-negative
+      event: select-tnbc-regimen
+      phase: tnbc
+      when:
+        tnbc-ct1ab-n0: Yes
+      then:
+        - avoid-neoadjuvant-therapy-for-small-tnbc
+      evidence_traceability_ids: [claim-r3-2]
+      provenance:
+        source: source_direct
+    - id: rule-r3-3-carboplatin
+      event: select-tnbc-regimen
+      phase: tnbc
+      when:
+        tnbc-node-positive-or-t1c-plus: Yes
+        benefit-harm-favors-carboplatin: Yes
+      then:
+        - consider-carboplatin-for-tnbc
+      evidence_traceability_ids: [claim-r3-3]
+      provenance:
+        source: source_direct
+    - id: rule-r3-4-no-ici
+      event: select-tnbc-regimen
+      phase: tnbc
+      then:
+        - avoid-routine-immune-checkpoint-inhibitors
+      evidence_traceability_ids: [claim-r3-4]
+      provenance:
+        source: source_direct
+    - id: rule-r4-1-use-chemo
+      event: select-hr-her2-negative-regimen
+      phase: hr-her2-negative
+      when:
+        hr-positive-her2-negative-disease: Yes
+        chemo-decision-without-surgical-data: Yes
+      then:
+        - use-neoadjuvant-chemotherapy-without-surgical-data
+      evidence_traceability_ids: [claim-r4-1]
+      provenance:
+        source: source_direct
+    - id: rule-r4-2-postmenopausal-endocrine
+      event: select-hr-her2-negative-regimen
+      phase: hr-her2-negative
+      when:
+        hr-positive-her2-negative-disease: Yes
+        postmenopausal: Yes
+      then:
+        - offer-postmenopausal-neoadjuvant-endocrine-therapy
+      evidence_traceability_ids: [claim-r4-2]
+      provenance:
+        source: source_direct
+    - id: rule-r4-2-no-surgery
+      event: select-hr-her2-negative-regimen
+      phase: hr-her2-negative
+      when:
+        hr-positive-her2-negative-disease: Yes
+        no-surgery-intended: Yes
+      then:
+        - use-endocrine-therapy-for-disease-control
+      evidence_traceability_ids: [claim-r4-2]
+      provenance:
+        source: source_direct
+    - id: rule-r4-3-premenopausal
+      event: select-hr-her2-negative-regimen
+      phase: hr-her2-negative
+      when:
+        hr-positive-her2-negative-disease: Yes
+        premenopausal: Yes
+      then:
+        - avoid-premenopausal-neoadjuvant-endocrine-therapy
+      evidence_traceability_ids: [claim-r4-3]
+      provenance:
+        source: source_direct
+    - id: rule-r5-1-her2-high-risk
+      event: select-her2-positive-regimen
+      phase: her2-positive
+      when:
+        her2-positive-high-risk: Yes
+      then:
+        - offer-her2-directed-neoadjuvant-regimen
+        - consider-pertuzumab-with-trastuzumab
+      evidence_traceability_ids: [claim-r5-1]
+      provenance:
+        source: source_direct
+    - id: rule-r5-2-small-her2-positive
+      event: select-her2-positive-regimen
+      phase: her2-positive
+      when:
+        her2-t1ab-n0: Yes
+      then:
+        - avoid-neoadjuvant-therapy-for-small-her2-positive
+      evidence_traceability_ids: [claim-r5-2]
+      provenance:
+        source: source_direct
