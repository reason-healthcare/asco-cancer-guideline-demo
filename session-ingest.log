+      then:
+        - offer-her2-directed-neoadjuvant-regimen
+        - consider-pertuzumab-with-trastuzumab
+      evidence_traceability_ids: [claim-r5-1]
+      provenance:
+        source: source_direct
+    - id: rule-r5-2-small-her2-positive
+      event: select-her2-positive-regimen
+      phase: her2-positive
+      when:
+        her2-t1ab-n0: Yes
+      then:
+        - avoid-neoadjuvant-therapy-for-small-her2-positive
+      evidence_traceability_ids: [claim-r5-2]
+      provenance:
+        source: source_direct
