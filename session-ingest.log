+      evidence_traceability_ids: [claim-r3-4]
+      provenance:
+        source: inferred
+        rationale: The guideline states evidence is insufficient to recommend routine addition of immune checkpoint inhibitors.
+    - id: use-neoadjuvant-chemotherapy-without-surgical-data
+      label: Use neoadjuvant chemotherapy when the chemotherapy decision does not require surgical data
+      description: Neoadjuvant chemotherapy can substitute for adjuvant chemotherapy in HR-positive HER2-negative disease when surgical pathology or genomic testing is not required for the decision.
+      kind: MedicationRequest
+      evidence_traceability_ids: [claim-r4-1]
